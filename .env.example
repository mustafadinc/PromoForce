# AI provider: openai | custom
AI_PROVIDER=openai

# OpenAI — required when AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key

# Image generation
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium
# Partial preview frames during streaming (0-3). 0 = faster, more reliable (recommended).
OPENAI_IMAGE_PARTIALS=0

# Optional: chat revises each background prompt before image gen (costly — default off)
OPENAI_REVISE_PROMPTS=0

# Optional: polish pass after composite (OpenAI Images edits — ~2x cost)
OPENAI_POLISH_PASS=0

# Strategy + optional prompt revision
OPENAI_CHAT_MODEL=gpt-4o-mini
# Optional: higher-detail screenshot intelligence (defaults to OPENAI_CHAT_MODEL)
# OPENAI_VISION_MODEL=gpt-4o-mini

# Video render: Remotion (default). Set to ffmpeg to skip Remotion/Chromium.
# VIDEO_RENDER_ENGINE=ffmpeg

# Custom provider — only when AI_PROVIDER=custom
# AI_PROVIDER_ENDPOINT=https://your-provider-endpoint.example/generate
# AI_PROVIDER_API_KEY=your_secret_key

# Optional: generation canvas (default 1280x2784 — App Store aspect, API-safe)
# APP_STORE_GENERATION_SIZE=1280x2784

MAX_UPLOAD_SIZE_MB=10

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Auth.js
# Set to 1 to skip login during local dev (no Google OAuth required)
AUTH_DISABLED=1
AUTH_SECRET=generate_with_openssl_rand_base64_32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=promoforce-assets
R2_PUBLIC_URL=

# Meta (Instagram) — dev mode until App Review
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/oauth/meta/callback

# X (Twitter) API
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/oauth/x/callback

# Optional: full path to ffmpeg binary (Windows: ffmpeg.exe). Auto-detected from node_modules/ffmpeg-static when omitted.
# FFMPEG_BIN=

# Inngest (background jobs)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Cron secret (Vercel)
CRON_SECRET=

# Stripe (optional — /pricing checkout)
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# Monitoring (optional)
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
